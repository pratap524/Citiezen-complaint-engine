# Environment Variables for Citizen Complaint Intelligence Engine

# MongoDB Connection String
# Get from MongoDB Atlas or local MongoDB
# Preferred (works on most networks)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/citizen_complaints?retryWrites=true&w=majority

# Fallback if SRV DNS fails with querySrv ECONNREFUSED
# MONGODB_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/?authSource=admin&replicaSet=<replicaSetName>&tls=true&retryWrites=true&w=majority

# Server Port
PORT=5000

# Client URL for CORS (your frontend URL)
CLIENT_URL=http://localhost:3000

# Flask AI classifier endpoint (run ai_predictive/app.py on port 5001)
AI_CLASSIFIER_URL=http://127.0.0.1:5001/api/classify

# Optional: If you want to add authentication later
# JWT_SECRET=your_jwt_secret_here